# Get this from @BotFather on Telegram after creating your bot
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Provided automatically by Railway's Postgres plugin — copy its value here
# (Railway lets you reference it as a variable too: ${{Postgres.DATABASE_URL}})
DATABASE_URL=postgresql://user:password@host:5432/railway

# Your Railway app's public domain (Settings -> Networking -> Generate Domain)
PUBLIC_URL=https://your-app.up.railway.app

PORT=3000
